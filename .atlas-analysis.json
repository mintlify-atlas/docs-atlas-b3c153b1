  "keyFeatures": [
    "Multithreaded job execution backed by PostgreSQL ACID transactions and advisory locks",
    "Native Postgres LISTEN/NOTIFY for low-latency job pickup",
    "Concurrency controls and throttling at enqueue and perform time",
    "Cron-style repeating/recurring job scheduling via the fugit gem",
    "Job batches with finish/success/discard callbacks",
    "Bulk enqueue via single INSERT statement",
    "Built-in web dashboard (mountable Rails Engine) with live polling",
    "Job labels for metadata, search, and concurrency scoping",
    "Pausing job execution by queue or job class",
    "HTTP health check probes for Kubernetes/containerized deployments",
    "Systemd sd_notify integration",
    "PgBouncer compatibility via SKIP LOCKED strategy"
  ],
  "publicApiSurface": [
