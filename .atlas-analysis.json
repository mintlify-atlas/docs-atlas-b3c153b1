  "projectType": "sdk-library",
  "projectName": "GoodJob",
  "projectDescription": "A multithreaded, Postgres-based Active Job backend for Ruby on Rails that provides reliable job execution, concurrency controls, cron scheduling, batches, and a built-in web dashboard.",
